{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Represents an inventory item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "minQuantity": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "sku", "price", "quantity", "userId"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["name", "userId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Stock change record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "type": { "type": "string", "enum": ["IN", "OUT", "ADJUSTMENT"] },
        "quantity": { "type": "number" },
        "previousQuantity": { "type": "number" },
        "newQuantity": { "type": "number" },
        "userId": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "type", "quantity", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of inventory products"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "History of stock changes"
    }
  }
}
