rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Products
    match /products/{productId} {
      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.sku is string && data.sku.size() > 0 && data.sku.size() <= 100
          && data.price is number && data.price >= 0
          && data.quantity is number && data.quantity >= 0
          && data.userId == request.auth.uid;
      }

      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(productId)
        && isValidProduct(request.resource.data)
        && request.resource.data.createdAt == request.time;

      allow update: if isSignedIn()
        && isOwner(resource.data.userId)
        && isValidProduct(request.resource.data)
        && (
          // Action: Edit info
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'sku', 'description', 'price', 'category', 'imageUrl', 'minQuantity', 'updatedAt']) ||
          // Action: Adjust stock
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity', 'updatedAt'])
        )
        && request.resource.data.updatedAt == request.time
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // Categories
    match /categories/{categoryId} {
      function isValidCategory(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.userId == request.auth.uid;
      }

      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(categoryId)
        && isValidCategory(request.resource.data);

      allow update: if isSignedIn()
        && isOwner(resource.data.userId)
        && isValidCategory(request.resource.data);

      allow delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // Transactions
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.productId is string
          && data.type in ['IN', 'OUT', 'ADJUSTMENT']
          && data.quantity is number
          && data.userId == request.auth.uid;
      }

      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(transactionId)
        && isValidTransaction(request.resource.data)
        && request.resource.data.createdAt == request.time
        && exists(/databases/$(database)/documents/products/$(request.resource.data.productId))
        && get(/databases/$(database)/documents/products/$(request.resource.data.productId)).data.userId == request.auth.uid;

      // Transactions are usually immutable
      allow update, delete: if false;
    }

    // User Settings (Shopify credentials, etc.)
    match /user_settings/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
